# ── Turso / libSQL ────────────────────────────────────────────────────────────
# From `turso db show <name> --url` and `turso db tokens create <name>`
TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
TURSO_AUTH_TOKEN=

# ── Google OAuth (Google Health API) ─────────────────────────────────────────
# OAuth client of type "Web application" in Google Cloud Console.
# Add BOTH redirect URIs to the client:
#   http://localhost:8787/oauth/callback        (one-time CLI auth flow)
#   https://<your-app>.vercel.app/api/auth/google/callback   (re-auth from the web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Token encryption ──────────────────────────────────────────────────────────
# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── LLM (summaries + text-to-SQL) ─────────────────────────────────────────────
# Default: a local model via Ollama (free, private) — tried first; if Ollama
# is unreachable, falls back to Gemini (when GEMINI_API_KEY is set), else
# Anthropic. Force a provider with LLM_PROVIDER=ollama|gemini|anthropic.
# qwen3 (8B) generates valid SQL fast without thinking mode; larger/thinking
# models are slower without being more reliable here:
#   ollama pull qwen3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3
#LLM_PROVIDER=ollama

# Cloud fallback: a free Gemini API key from https://aistudio.google.com/apikey
# (the free tier is separate from any Gemini consumer subscription).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic fallback/alternative (optional if using Gemini)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather; chat id from @userinfobot (or getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Random string used to authenticate Telegram webhook calls. Generate with:
# openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=

# ── Dashboard access ──────────────────────────────────────────────────────────
# Shared secret that gates the whole web app. Generate with: openssl rand -hex 16
DASHBOARD_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of the deployed dashboard (no trailing slash). Used for OAuth
# re-auth links sent to Telegram and for the Telegram webhook.
APP_URL=https://your-app.vercel.app
# IANA timezone for "day" boundaries, the morning brief, and civil-time filters.
APP_TIMEZONE=Europe/London
# How many days of history to backfill on the very first sync.
SYNC_LOOKBACK_DAYS=30
# Your age — sets HR-max (Tanaka: 208 − 0.7·age) for heart-rate zone boundaries
# and training-load (TRIMP) on the dashboard. Defaults to 30 if unset.
HEALCHA_AGE=30
# Daily step goal for the "Your day" ring on the dashboard. Defaults to 9000.
STEPS_GOAL=9000
# Ignore data before this local date (YYYY-MM-DD) everywhere on the dashboard —
# useful after a device switch or when older history is irrelevant. Unset ⇒ all.
#DATA_START_DATE=
