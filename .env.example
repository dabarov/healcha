# Everything here is OPTIONAL. The app configures itself on first run
# (Google credentials via the in-app setup, encryption key auto-generated,
# database in the local data dir). Env vars override the stored config —
# useful for the browser mode, CLI scripts, or pointing at a remote DB.

# ── Storage ───────────────────────────────────────────────────────────────────
# Where the database + config.json live. Defaults to ./local/data in the repo;
# the desktop app uses the OS app-data dir instead.
#HEALCHA_DATA_DIR=
# Any libsql URL: another file path, or a remote Turso database.
#TURSO_DATABASE_URL=file:local/data/healcha.db
#TURSO_AUTH_TOKEN=

# ── Google OAuth (Google Health API) ─────────────────────────────────────────
# Normally entered in the app's setup screen; set here to skip that.
# OAuth client of type "Web application" with redirect URI
#   http://localhost:3000/api/auth/google/callback   (browser mode)
#   http://localhost:4823/api/auth/google/callback   (desktop app)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# 64 hex chars (openssl rand -hex 32); auto-generated into config.json if unset.
#TOKEN_ENCRYPTION_KEY=

# ── LLM (daily brief + chat) ──────────────────────────────────────────────────
# Default: a local model via Ollama (free, private) — tried first; if Ollama
# is unreachable, falls back to Gemini (when GEMINI_API_KEY is set), else
# Anthropic. Force a provider with LLM_PROVIDER=ollama|gemini|anthropic.
# qwen3 (8B) generates valid SQL fast without thinking mode:
#   ollama pull qwen3
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen3
#LLM_PROVIDER=ollama

# Cloud fallback: a free Gemini API key from https://aistudio.google.com/apikey
#GEMINI_API_KEY=
#GEMINI_MODEL=gemini-2.5-flash

# Anthropic fallback/alternative
#ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-haiku-4-5

# ── Tuning ────────────────────────────────────────────────────────────────────
# IANA timezone for "day" boundaries. Defaults to the system timezone.
#APP_TIMEZONE=Europe/London
# Days of history to backfill on the very first sync (default 30).
#SYNC_LOOKBACK_DAYS=30
# Your age — sets HR-max (Tanaka: 208 − 0.7·age) for heart-rate zones and
# training load. Defaults to 30.
#HEALCHA_AGE=30
# Daily step goal for the "Your day" ring (default 9000).
#STEPS_GOAL=9000
# Ignore data before this local date (YYYY-MM-DD) — e.g. after a device
# switch. Unset ⇒ all history.
#DATA_START_DATE=
# Port the desktop app serves on (default 4823).
#HEALCHA_PORT=
