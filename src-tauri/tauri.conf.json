{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "healcha",
  "version": "0.1.0",
  "identifier": "com.dabarov.healcha",
  "build": {
    "beforeDevCommand": "node scripts/fetch-node.mjs && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build && node scripts/fetch-node.mjs",
    "frontendDist": "http://127.0.0.1:4823"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": {
      "../.next/standalone": "server"
    }
  }
}
